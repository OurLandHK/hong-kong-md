---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/home/HeroSection.astro';
import CoverStory from '../../components/home/CoverStory.astro';
import RandomDiscovery from '../../components/home/RandomDiscovery.astro';
import CategoriesSection from '../../components/home/CategoriesSection.astro';
import RecentUpdates from '../../components/home/RecentUpdates.astro';
import NewsletterSection from '../../components/home/NewsletterSection.astro';
import ContributeSection from '../../components/home/ContributeSection.astro';
import LanguageStatement from '../../components/home/LanguageStatement.astro';
import ReadingPath from '../../components/ReadingPath.astro';
import FeatureCards from '../../components/FeatureCards.astro';
import { fetchRecentCommits } from '../../lib/commits';
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';

// Fetch recent commits
const recentCommits = await fetchRecentCommits();

// Build article list for RandomDiscovery
const categories = [
  { id: 'history', name: 'History', folder: 'History' },
  { id: 'geography', name: 'Geography', folder: 'Geography' },
  { id: 'culture', name: 'Culture', folder: 'Culture' },
  { id: 'food', name: 'Food', folder: 'Food' },
  { id: 'art', name: 'Art', folder: 'Art' },
  { id: 'music', name: 'Music', folder: 'Music' },
  { id: 'technology', name: 'Technology', folder: 'Technology' },
  { id: 'nature', name: 'Nature', folder: 'Nature' },
  { id: 'people', name: 'People', folder: 'People' },
  { id: 'society', name: 'Society', folder: 'Society' },
  { id: 'economy', name: 'Economy', folder: 'Economy' },
  { id: 'lifestyle', name: 'Lifestyle', folder: 'Lifestyle' },
];

let allArticles: { title: string; url: string; category: string }[] = [];

for (const cat of categories) {
  try {
    const folderPath = resolve(process.cwd(), 'knowledge', 'en', cat.folder);
    const files = await readdir(folderPath);
    const mdFiles = files.filter(
      (f) => f.endsWith('.md') && !f.startsWith('_'),
    );

    for (const file of mdFiles) {
      const content = await readFile(join(folderPath, file), 'utf-8');
      const { data: frontmatter } = matter(content);
      const slug = basename(file, '.md');
      allArticles.push({
        title: frontmatter.title || slug,
        url: `/en/${cat.id}/${slug}`,
        category: cat.name,
      });
    }
  } catch {
    // folder doesn't exist, skip
  }
}

const randomArticlesData = JSON.stringify(allArticles);

const readingPathSteps = [
  {
    href: '/en/history/handover',
    title: "One Country, Two Systems: Hong Kong's Handover",
    description:
      'From British colony to Special Administrative Region — a unique transition in modern history',
    time: '6 min',
  },
  {
    href: '/en/culture/cantonese-opera',
    title: 'Living Heritage: Cantonese Opera',
    description:
      'A centuries-old art form that remains the cultural heartbeat of Hong Kong',
    time: '7 min',
  },
  {
    href: '/en/food/cha-chaan-teng',
    title: 'The Real Taste of Hong Kong: Cha Chaan Teng',
    description:
      "Hong Kong's iconic diners where East meets West on every plate",
    time: '5 min',
  },
  {
    href: '/en/economy/financial-hub',
    title: "Asia's World City: Financial Hub",
    description:
      'How a fishing village became one of the top 3 financial centers on Earth',
    time: '8 min',
  },
  {
    href: '/en/lifestyle/mtr-culture',
    title: 'Life Operating System: The MTR',
    description:
      'More than a railway — it\'s the backbone of how 7.5 million people move',
    time: '4 min',
  },
];

const readingPathFooterItems = [
  { icon: '⏱️', label: 'Total 30 minutes' },
  { icon: '🎯', label: '5 key domains' },
  { icon: '🌟', label: 'Complete Hong Kong overview' },
];
---

<Layout
  title="Open Knowledge Base of Hong Kong"
  description="The open-source, AI-friendly knowledge base about Hong Kong. 660+ pages covering history, culture, food, music, technology and more — written by the community, for the world."
  lang="en"
>
  <HeroSection />

  <CoverStory />

  <FeatureCards
    lang="en"
    sectionTitle="Why HongKong.md?"
    cards={[
      {
        icon: '🎯',
        title: 'Curated Perspectives',
        description:
          'Carefully curated deep narratives, not encyclopedic listings',
      },
      {
        icon: '🤖',
        title: 'AI-Friendly Design',
        description:
          "Structured content that helps AI understand Hong Kong's complexity",
      },
      {
        icon: '🌍',
        title: 'Bilingual Global Vision',
        description:
          "Starting from local perspectives, telling Hong Kong's story in global languages",
      },
      {
        icon: '📚',
        title: 'Complete Multi-dimensional',
        description:
          "Covering 12+ domains, presenting Hong Kong's three-dimensional complete picture",
      },
    ]}
  />

  <RandomDiscovery articlesJson={randomArticlesData} />

  <ReadingPath
    lang="en"
    title="📖 Don't know where to start?"
    subtitle="Discover the real Hong Kong in 30 minutes with these 5 essential articles"
    steps={readingPathSteps}
    footerItems={readingPathFooterItems}
    continueHref="#categories"
    continueLabel="Continue exploring more topics →"
  />

  <LanguageStatement />

  <CategoriesSection>
    <Fragment slot="prose">
      <p>
        This city spans just 1,114 square kilometers, yet contains a
        microcosm of the entire world. From the 957-meter peak of Tai Mo Shan to
        the deep channels of Victoria Harbour,
        <a href={`${import.meta.env.BASE_URL}en/geography`} class="topic-pill"
          >🗺️ the geography here</a
        > is itself a tug-of-war between human ambition and nature —
        land reclamation, hilltop leveling, skyscrapers rising from bedrock. Over
        a century of relentless urban evolution has forged the most densely packed
        and dazzling Pearl of the Orient on Earth.
      </p>

      <p>
        Over 180 years ago, the British landed at Possession Point. Since
        then, every turning point — the Japanese occupation, waves of refugees,
        the twilight of colonial rule, the handover — has carved its own
        inscription on this city. But what truly makes Hong Kong Hong Kong is
        that journey from <a
          href={`${import.meta.env.BASE_URL}en/history`}
          class="topic-pill">📜 "a borrowed place" to the awakening of local identity</a
        >. From the reflection after the 1967 riots to the resonance of "Below the
        Lion Rock," from the passion for democracy to the questioning of identity,
        every moment of pain and struggle has made this city's soul clearer.
      </p>

      <p>
        Multiple bloodlines flow through this land. The Tanka fisherfolk and
        walled village inhabitants who have lived here for centuries, the
        Cantonese and Hakka who migrated south after the 17th century, the
        refugees who fled from every province of mainland China after the war,
        and recent new immigrants and ethnic minorities — each group brought
        their own languages, beliefs, and memories.
        <a href={`${import.meta.env.BASE_URL}en/culture`} class="topic-pill"
          >🎭 Hong Kong's culture</a
        > is not a melting pot, but a puzzle — each piece maintaining its own color
        and shape, assembled into an unprecedented picture where East meets West
        and Chinese and Western traditions intertwine.
      </p>

      <p>
        Walk into any Hong Kong street, and you'll simultaneously smell
        the rich aroma of Cantonese roast meats, the silky fragrance of
        milk tea, and the satay and spices brought by Southeast Asian
        migrant workers.
        <a href={`${import.meta.env.BASE_URL}en/food`} class="topic-pill"
          >🍜 This city's flavors</a
        >
        are the gustatory version of its immigration history. From dai pai dong
        street stalls' human warmth to Michelin restaurants' precision, Hong Kong
        people tell stories through food, preserve memories through cuisine.
      </p>

      <p>
        This is not just a steel jungle — it's an ecological miracle.
        In this tiny, densely populated city, a full 40% of the land is
        designated as country parks.
        <a href={`${import.meta.env.BASE_URL}en/nature`} class="topic-pill"
          >🌿 Hong Kong's nature</a
        > is a three-dimensional book of symbiosis: from tranquil mangroves to the
        dramatic columnar rock formations of High Island Reservoir, from Chinese
        white dolphins to migrating black-faced spoonbills, wild boars crossing
        paths with hikers on mountain trails. But the cost of urban expansion is
        also written along the coastline, as the tug-of-war between conservation
        and development never ceases.
      </p>

      <p>
        From Jin Yong and Ni Kuang to Xi Xi and Leung Ping-kwan, from the
        Ho Tung family to the legend of Li Ka-shing,
        <a href={`${import.meta.env.BASE_URL}en/people`} class="topic-pill"
          >👥 Hong Kong's figures</a
        > are microcosms of their times. They are not just individual biographies,
        but collective memories of how this city survived at the crossroads of East
        and West, finding hope in hardship. Behind every story are the resilience
        and choices of ordinary people in extraordinary times.
      </p>

      <p>
        From the incense smoke of Wong Tai Sin Temple to the contemporary
        visions of the West Kowloon Cultural District,
        <a href={`${import.meta.env.BASE_URL}en/art`} class="topic-pill"
          >🎨 Hong Kong's art</a
        > is a dialogue between tradition and trend. Cantonese opera and modern
        dance, neon signs and digital art, street graffiti and Art Basel — artists
        constantly ask: How do we respond to this changing era through creation?
        How do we maintain local identity amid intense commercialization?
      </p>

      <p>
        From the classic Cantopop of James Wong and Joseph Koo to Beyond's
        anthems of resistance, from the golden age of Cantonese pop to
        today's indie bands,
        <a href={`${import.meta.env.BASE_URL}en/music`} class="topic-pill"
          >🎵 Hong Kong's sounds</a
        > are the city's heartbeat. Music transcends class and generation, becoming
        the most powerful carrier of collective memory. Whether it's a 10,000-strong
        singalong at the Hong Kong Coliseum or a raw scream in a livehouse, they
        all tell the same story: who we are, and where we're going.
      </p>

      <p>
        Hong Kong's finance and entrepôt trade are not just numbers, but
        proof of its position on the global map.
        <a href={`${import.meta.env.BASE_URL}en/technology`} class="topic-pill"
          >💻 This free port</a
        > has evolved from manufacturing to an international financial center,
        seeking its edge through its legal system and professional services. But
        technology and the times also bring challenges: sky-high property prices,
        industrial concentration, competitiveness transitions — how does Hong Kong
        ride the regional wave without being swept away?
      </p>

      <p>
        From one of Asia's Four Little Dragons to the heart of the Greater
        Bay Area,
        <a href={`${import.meta.env.BASE_URL}en/economy`} class="topic-pill"
          >📈 Hong Kong's economic miracle</a
        >
        is a textbook case of "positive non-interventionism" and nimble adaptation.
        But behind the miracle are countless late nights, relentless efficiency,
        and a fierce drive to survive. Now facing global realignment, how does
        Hong Kong continue writing its financial legend?
      </p>

      <p>
        <a href={`${import.meta.env.BASE_URL}en/society`} class="topic-pill"
          >⚖️ Hong Kong's society</a
        >'s keywords are "rule of law" and "resilience." From steadfast
        commitment to core values to spirited debate on social issues, from
        housing justice to the challenges of an aging population, Hong Kong
        people are learning how to safeguard their convictions through upheaval
        and find consensus through collision. This is history's laboratory and
        resilience's proving ground.
      </p>

      <p>
        Hong Kong people's <a
          href={`${import.meta.env.BASE_URL}en/lifestyle`}
          class="topic-pill">🏠 lifestyle</a
        > is a blend of "fast" and "hustle." The MTR's transfer efficiency is
        world-class, yet the cha chaan teng's rhythm is one of a kind. Within the
        24/7 urban beat, the pursuit of quality and neighborhood humor endure. In
        globalization's torrent, how do Hong Kong people maintain their life
        philosophy? The answer might lie in that daily wisdom: "hurry up" and
        "the most important thing is to be happy."
      </p>
    </Fragment>
  </CategoriesSection>

  <RecentUpdates commits={recentCommits} />

  <NewsletterSection />

  <ContributeSection />
</Layout>

<style>
  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    text-align: center;
    color: #1a1a2e;
    margin-bottom: 1rem;
  }
</style>
