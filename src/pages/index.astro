---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import CoverStory from '../components/home/CoverStory.astro';
import RandomDiscovery from '../components/home/RandomDiscovery.astro';
import ReadingPath from '../components/ReadingPath.astro';
import FeatureCards from '../components/FeatureCards.astro';
import CategoriesSection from '../components/home/CategoriesSection.astro';
import LanguageStatement from '../components/home/LanguageStatement.astro';
import RecentUpdates from '../components/home/RecentUpdates.astro';
import NewsletterSection from '../components/home/NewsletterSection.astro';
import CommunityFeedback from '../components/home/CommunityFeedback.astro';
import ContributeSection from '../components/home/ContributeSection.astro';

import { fetchRecentCommits } from '../lib/commits';
import { feedbacks } from '../data/feedbacks';

const recentCommits = await fetchRecentCommits();

const readingPathSteps = [
  {
    href: '/history/民主化',
    title: '寧靜革命：香港民主化',
    description: '從威權到民主，亞洲第一的和平轉型奇蹟',
    time: '6 min',
  },
  {
    href: '/culture/族群（閩南客家原住民外省新住民）',
    title: '多元一體：香港族群',
    description: '四大族群共同編織的多彩文化基底',
    time: '7 min',
  },
  {
    href: '/food/夜市文化',
    title: '最真實的香港味：夜市文化',
    description: '密度世界第一的庶民美食社交空間',
    time: '5 min',
  },
  {
    href: '/technology/半導體產業',
    title: '護國神山：半導體產業',
    description: '台積電如何讓小島成為全球科技心臟',
    time: '8 min',
  },
  {
    href: '/lifestyle/便利商店文化',
    title: '生活作業系統：便利商店',
    description: '不只是商店，而是整個國家的基礎建設',
    time: '4 min',
  },
];

const readingPathFooterItems = [
  { icon: '⏱️', label: '總計 30 分鐘' },
  { icon: '🎯', label: '跨越 5 大領域' },
  { icon: '🌟', label: '完整認識香港' },
];
---

<Layout
  title="開源香港知識庫"
  description="開源、AI-friendly 的香港完整知識庫。660+ 頁深度內容涵蓋歷史、文化、美食、音樂、科技等 12 大主題，由社群共同編撰，讓全世界認識真正的香港。"
>
  <HeroSection />

  <CoverStory />

  <RandomDiscovery />

  <ReadingPath
    title="📖 不知道從哪開始？"
    subtitle="用這 5 篇文章，在 30 分鐘內認識真正的香港"
    steps={readingPathSteps}
    footerItems={readingPathFooterItems}
    continueHref="#categories"
    continueLabel="繼續探索更多主題 →"
  />

  <FeatureCards
    lang="zh-HK"
    sectionTitle="為什麼需要 HongKong.md？"
    cards={[
      {
        icon: '🎯',
        title: '策展式觀點',
        description: '精心策展的深度敘事，不是百科全書式羅列',
      },
      {
        icon: '🤖',
        title: 'AI-Friendly 設計',
        description: '結構化內容，讓AI也能理解香港的複雜性',
      },
      {
        icon: '🌍',
        title: '雙語國際視野',
        description: '從在地觀點出發，用國際語言說香港故事',
      },
      {
        icon: '📚',
        title: '完整多面向',
        description: '涵蓋12+領域，呈現香港的立體完整面貌',
      },
    ]}
  >
    <div class="features-cta">
      <a href={`${import.meta.env.BASE_URL}graph`} class="feature-btn"
        >🔗 知識圖譜 — 探索文章之間的連結</a
      >
      <a
        href="https://github.com/OurLandHK/hong-kong-md/tree/main/knowledge"
        target="_blank"
        rel="noopener noreferrer"
        class="feature-btn secondary">📂 瀏覽 SSOT 原始資料 ↗</a
      >
    </div>
  </FeatureCards>

  <section class="mini-graph-section">
    <a href={`${import.meta.env.BASE_URL}graph`} class="mini-graph-link">
      <div class="mini-graph-text">
        <h3>🕸️ 知識圖譜</h3>
        <p>每篇文章都不是孤島——點擊探索香港知識的連結網絡</p>
      </div>
      <div id="mini-graph" class="mini-graph-container"></div>
    </a>
  </section>

  <CategoriesSection>
    <Fragment slot="prose">
      <p>
        這座城市只有 1,114 平方公里，卻壓縮了整個世界的縮影。從 957 公尺的大帽山之巔到維多利亞港的深邃航道，
        <a href={`${import.meta.env.BASE_URL}geography`} class="topic-pill"
          >🗺️ 這裡的地理</a
        >本身就是一場人工與自然的拉鋸戰——
        填海造地、削平山頭、摩天大樓在岩石上拔地而起。百多年來不停歇的城市演化，造就了這座世界上最稠密也最璀璨的東方之珠。
      </p>

      <p>
        一百八十多年前，英國人在水坑口登陸。此後的每一個轉折——日佔時期、難民潮、殖民末期、回歸——都在這座城刻下了自己的銘文。但真正讓香港成為香港的，是那段從「借來的地方」到<a
          href={`${import.meta.env.BASE_URL}history`}
          class="topic-pill">📜 本土意識的覺醒</a
        >。 從六七暴動的反思到獅子山下的共鳴，從爭取民主的熱忱到對身分的叩問，每一次的痛苦與掙扎，都讓這座城的靈魂更加清晰。
      </p>

      <p>
        這片土地上流淌著多重血液。原居於此的蜑家漁民與圍村村民，十七世紀後南下的廣府人、客家人，戰後從大陸各省避難而來的移民，近年的新移民與少數族裔，每一群人都帶來了自己的語言、信仰與記憶。
        <a href={`${import.meta.env.BASE_URL}culture`} class="topic-pill"
          >🎭 香港的文化</a
        >不是熔爐，而是拼圖——
        每一塊都保持著自己的顏色與形狀，拼湊出一幅中西合璧、華洋雜處的前所未有圖像。
      </p>

      <p>
        走進任何一條香港的街道，你會同時聞到廣式燒臘的油香、絲滑奶茶的茶氣、和東南亞移工帶來的沙嗲與香料。<a
          href={`${import.meta.env.BASE_URL}food`}
          class="topic-pill">🍜 這座城的味道</a
        >， 就是它的移民史的味覺版本。從大牌檔的人情味到米其林餐廳的極致精工，香港人用食物說故事，用料理保存記憶。
      </p>

      <p>
        這不只是鋼鐵森林，更是生態的奇跡。在這個地狹人稠的城市，竟有 40% 的土地被劃為郊野公園。
        <a href={`${import.meta.env.BASE_URL}nature`} class="topic-pill"
          >🌿 香港的自然</a
        >是一部立體的共生史書：從幽靜的紅樹林到險峻的萬宜水庫柱狀岩，從中華白海豚到過境的黑臉琵鷺，野豬與居民在山徑相遇。但城市擴張的代價也寫在海岸線裡，環保與發展的拉扯從未停止。
      </p>

      <p>
        從金庸、倪匡到西西、也斯，從何東家族到李嘉誠的傳奇，
        <a href={`${import.meta.env.BASE_URL}people`} class="topic-pill"
          >👥 香港的人物</a
        >是時代的縮影。他們不只是個人的傳記，更是這座城市如何在東西交匯中求生存、在困頓中找希望的集體記憶。每一個故事背後，都是大時代下小人物的堅韌與選擇。
      </p>

      <p>
        從黃大仙廟的香火到西九文化區的當代視覺，
        <a href={`${import.meta.env.BASE_URL}art`} class="topic-pill"
          >🎨 香港的藝術</a
        >是傳統與潮流的對話。粵劇與現代舞、霓虹燈招牌與數位藝術、街頭塗鴉與巴塞爾藝術展——藝術家們不斷在問：我們如何用創作回應這個變動的時代？如何在高度商業化中保持在地性？
      </p>

      <p>
        從黃霑、顧嘉輝的經典粵語歌到 Beyond 的抗爭之音，從廣東歌的黃金時代到當代獨立樂隊，
        <a href={`${import.meta.env.BASE_URL}music`} class="topic-pill"
          >🎵 香港的聲音</a
        >是島嶼的心跳。
        是城鎮的心跳。音樂跨越了階層與世代，成為最能凝聚共同記憶的載體。無論是紅館萬人大合唱，還是 Livehouse 裡的嘶吼，都在述說著同一個故事：我們是誰，我們要往哪裡去。
      </p>

      <p>
        香港的金融與轉口貿易不只是數字，而是它在全球版圖上的定位證明。
        <a href={`${import.meta.env.BASE_URL}technology`} class="topic-pill"
          >💻 這座自由港</a
        >從製造業轉型為國際金融中心，在法律體系與專業服務中尋求優勢。但科技與時代也帶來了挑戰：樓價高企、產業單一、競爭力轉型——香港如何在區域浪潮中既衝浪又不被淹沒？
      </p>

      <p>
        從亞洲四小龍到大灣區的核心，<a
          href={`${import.meta.env.BASE_URL}economy`}
          class="topic-pill">📈 香港的經濟奇蹟</a
        >
        是「不干預政策」與靈活應變的典型案例。但奇蹟背後是無數個趕工的夜晚、極致的效率追求、與對生存的強烈渴望。如今面對全球局勢的重組，香港如何繼續寫下金融傳奇？
      </p>

      <p>
        <a href={`${import.meta.env.BASE_URL}society`} class="topic-pill"
          >⚖️ 香港社會</a
        >的關鍵字是**「法治」與「靈活」**。從對核心價值的堅持，到社會議題的熱烈辯論，從居住正義到人口老化的挑戰，香港人正在學習如何在變局中守護初心，在碰撞中尋找共識。這是歷史的實驗室，也是韌性的試煉場。
      </p>

      <p>
        香港人的<a
          href={`${import.meta.env.BASE_URL}lifestyle`}
          class="topic-pill">🏠 生活方式</a
        >生活方式是「快」與「拼」的混合體。地鐵轉乘的效率世界第一，茶餐廳的節奏卻是獨一無二。24 小時不打烊的城市節奏裡，依然保留著對生活品質的追求與鄰里的幽默。在全球化的洪流中，香港人如何保持自己的生活哲學？答案或許就在那一句**「最緊要快」與「做人最緊要開心」**的日常智慧裡。
      </p>
    </Fragment>
  </CategoriesSection>

  <LanguageStatement />

  <RecentUpdates commits={recentCommits} />

  <NewsletterSection />

  <CommunityFeedback feedbacks={feedbacks} />

  <ContributeSection />
</Layout>

<script is:inline src="https://d3js.org/d3.v7.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const container = document.getElementById('mini-graph');
    if (container) {
      const categories = [
        { id: 'history', name: '歷史', color: '#dc2626' },
        { id: 'geography', name: '地理', color: '#2563eb' },
        { id: 'culture', name: '文化', color: '#7c3aed' },
        { id: 'food', name: '美食', color: '#ea580c' },
        { id: 'art', name: '藝術', color: '#db2777' },
        { id: 'music', name: '音樂', color: '#4f46e5' },
        { id: 'technology', name: '科技', color: '#0891b2' },
        { id: 'nature', name: '自然', color: '#16a34a' },
        { id: 'people', name: '人物', color: '#ca8a04' },
        { id: 'society', name: '社會', color: '#64748b' },
        { id: 'economy', name: '經濟', color: '#0d9488' },
        { id: 'lifestyle', name: '生活', color: '#f97316' },
      ];

      const nodes = [
        {
          id: 'hongkong',
          name: 'HongKong.md',
          size: 18,
          color: '#2d5016',
          group: 'core',
        },
        ...categories.map((c) => ({
          id: c.id,
          name: c.name,
          size: 12,
          color: c.color,
          group: 'category',
        })),
      ];

      const edges = categories.map((c) => ({
        source: 'hongkong',
        target: c.id,
      }));
      const crossLinks = [
        ['history', 'people'],
        ['history', 'society'],
        ['culture', 'art'],
        ['culture', 'music'],
        ['food', 'lifestyle'],
        ['technology', 'economy'],
        ['nature', 'geography'],
        ['people', 'art'],
        ['society', 'economy'],
        ['music', 'culture'],
        ['lifestyle', 'food'],
        ['geography', 'nature'],
      ];
      crossLinks.forEach(([source, target]) => edges.push({ source, target }));

      const width = container.clientWidth;
      const height = 300;

      const svg = d3
        .select('#mini-graph')
        .append('svg')
        .attr('viewBox', `0 0 ${width} ${height}`)
        .attr('preserveAspectRatio', 'xMidYMid meet');

      const simulation = d3
        .forceSimulation(nodes)
        .force(
          'link',
          d3
            .forceLink(edges)
            .id((d) => d.id)
            .distance(60),
        )
        .force('charge', d3.forceManyBody().strength(-120))
        .force('center', d3.forceCenter(width / 2, height / 2))
        .force(
          'collision',
          d3.forceCollide().radius((d) => d.size + 4),
        );

      const link = svg
        .append('g')
        .selectAll('line')
        .data(edges)
        .join('line')
        .attr('stroke', '#d1d5db')
        .attr('stroke-width', 1)
        .attr('stroke-opacity', 0.5);

      const node = svg
        .append('g')
        .selectAll('circle')
        .data(nodes)
        .join('circle')
        .attr('r', (d) => d.size)
        .attr('fill', (d) => d.color)
        .attr('fill-opacity', 0.85)
        .attr('stroke', '#fff')
        .attr('stroke-width', 1.5);

      const label = svg
        .append('g')
        .selectAll('text')
        .data(nodes)
        .join('text')
        .text((d) => d.name)
        .attr('text-anchor', 'middle')
        .attr('dy', (d) => d.size + 14)
        .attr('font-size', (d) => (d.group === 'core' ? '11px' : '9px'))
        .attr('font-weight', (d) => (d.group === 'core' ? '700' : '500'))
        .attr('fill', '#374151')
        .attr('pointer-events', 'none');

      simulation.on('tick', () => {
        link
          .attr('x1', (d) => d.source.x)
          .attr('y1', (d) => d.source.y)
          .attr('x2', (d) => d.target.x)
          .attr('y2', (d) => d.target.y);
        node.attr('cx', (d) => d.x).attr('cy', (d) => d.y);
        label.attr('x', (d) => d.x).attr('y', (d) => d.y);
      });
    }
  });
</script>



<style>
  /* ===== SKIP LINK FOR ACCESSIBILITY ===== */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 6px;
    background: #1a1a2e;
    color: white;
    padding: 8px 16px;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    z-index: 100;
    transition: top 0.3s ease;
  }

  .skip-link:focus {
    top: 6px;
  }

  /* ===== SECTION TITLE ===== */
  .section-title {
    font-family:
      'jf-lanyangming', 'Noto Serif TC', 'Source Han Serif TC', serif;
    font-size: 2rem;
    font-weight: 300;
    color: #1f2937;
    text-align: center;
  }

  /* ===== MINI GRAPH SECTION (ZH-only) ===== */
  .mini-graph-section {
    max-width: 800px;
    margin: 0 auto 4rem;
    padding: 0 2rem;
  }

  .mini-graph-link {
    display: block;
    text-decoration: none;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 2rem;
    transition: all 0.3s ease;
  }

  .mini-graph-link:hover {
    border-color: #2d5016;
    box-shadow: 0 4px 12px rgba(45, 80, 22, 0.1);
  }

  .mini-graph-text {
    text-align: center;
    margin-bottom: 1rem;
  }

  .mini-graph-text h3 {
    font-size: 1.3rem;
    color: #1f2937;
    margin-bottom: 0.5rem;
  }

  .mini-graph-text p {
    font-size: 0.95rem;
    color: #6b7280;
  }

  .mini-graph-container {
    width: 100%;
    height: 300px;
    overflow: hidden;
  }

  /* ===== FEATURES CTA (ZH-only slot content) ===== */
  .features-cta {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
    padding: 0 1rem;
  }

  .feature-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    background: #f0fdf4;
    border: 1.5px solid rgba(45, 80, 22, 0.2);
    border-radius: 8px;
    color: #2d5016;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.25s ease;
  }

  .feature-btn:hover {
    background: rgba(45, 80, 22, 0.1);
    border-color: rgba(45, 80, 22, 0.4);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(45, 80, 22, 0.15);
  }

  .feature-btn.secondary {
    background: #f8fafc;
    border-color: #d1d5db;
    color: #374151;
  }

  .feature-btn.secondary:hover {
    background: #f1f5f9;
    border-color: #9ca3af;
  }

  @media (max-width: 480px) {
    .features-cta {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
